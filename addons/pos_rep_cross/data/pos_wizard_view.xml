<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_rep_wizard_form" model="ir.ui.view">
        <field name="name">pos.sales.report.wizard.form</field>
        <field name="model">pos.sales.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Reporte Detallado de Ventas POS">
                <sheet>
                    <group invisible="not csv_file and not excel_file">
                        <group string="Descarga">
                            <field name="csv_filename" invisible="1"/>
                            <field name="excel_filename" invisible="1"/>
                            <field name="csv_file" filename="csv_filename" widget="binary" invisible="not csv_file"/>
                            <field name="excel_file" filename="excel_filename" widget="binary" invisible="not excel_file"/>
                        </group>
                    </group>
                    <group invisible="csv_file or excel_file">
                        <group string="Fechas">
                            <field name="date_from"/>
                            <field name="date_to"/>
                        </group>
                        <group string="Filtros">
                            <field name="state"/>
                        </group>
                    </group>
                    <notebook invisible="csv_file or excel_file">
                        <page string="Puntos de Venta" name="pos_configs">
                            <field name="pos_config_ids" widget="many2many_tags" placeholder="Todos los PdV..."/>
                        </page>
                        <page string="Sesiones" name="sessions">
                            <field name="session_ids" widget="many2many_tags" placeholder="Todas las sesiones..."/>
                        </page>
                        <page string="Cajeros" name="users">
                            <field name="user_ids" widget="many2many_tags" placeholder="Todos los cajeros..."/>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <div invisible="csv_file or excel_file">
                        <button name="action_generate_report_pdf" string="Imprimir PDF" type="object" class="btn-primary" icon="fa-file-pdf-o"/>
                        <button name="action_generate_report_xlsx" string="Exportar Excel" type="object" class="btn-secondary" icon="fa-file-excel-o"/>
                        <button name="action_generate_report_csv" string="Exportar CSV" type="object" class="btn-info" icon="fa-file-text-o"/>
                        <button string="Cancelar" class="btn-secondary" special="cancel"/>
                    </div>
                    <div invisible="not csv_file and not excel_file">
                        <button string="Cerrar" class="btn-primary" special="cancel"/>
                    </div>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_pos_report_wizard" model="ir.actions.act_window">
        <field name="name">Reporte detallado de ventas PDV</field>
        <field name="res_model">pos.sales.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_pos_rep_wizard_form"/>
    </record>

    <menuitem id="menu_pos_rep_cross"
              name="Reporte detallado de ventas PDV"
              parent="point_of_sale.menu_point_rep"
              action="action_pos_report_wizard"
              sequence="100"/>
</odoo>
