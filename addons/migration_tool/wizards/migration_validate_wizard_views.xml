<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_migration_validate_wizard" model="ir.ui.view">
        <field name="name">migration.validate.wizard.form</field>
        <field name="model">migration.validate.wizard</field>
        <field name="arch" type="xml">
            <form string="Validate Migration">
                <group>
                    <group>
                        <field name="config_id"/>
                    </group>
                </group>
                <group invisible="not result">
                    <field name="result" readonly="1" widget="text" nolabel="1" height="400"/>
                </group>
                <footer>
                    <button name="action_validate" string="Validate" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_migration_validate_wizard" model="ir.actions.act_window">
        <field name="name">Validate Migration</field>
        <field name="res_model">migration.validate.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
