<odoo>

    <!-- form view -->
    <record id="purchase_order_inherit_form" model="ir.ui.view">
        <field name="name">purchase.order.inherit.form</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form" />
        <field name="arch" type="xml">

            <xpath expr="//header" position="inside">
                <button name="action_reception_and_create_invoice"
                        string="Recepcionar y Crear Factura"
                        type="object"
                        class="oe_highlight"
                        invisible="state not in ['draft', 'sent', 'purchase']"/>
            </xpath>
        
        </field>
    </record>

</odoo>
