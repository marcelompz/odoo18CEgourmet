<odoo>

    <!-- list view -->
    <record id="product_brand_list" model="ir.ui.view">
        <field name="name">product.brand.list</field>
        <field name="model">product.brand</field>
        <field name="arch" type="xml">
            <list editable="top" sample="1">
                <field name="name" required="1"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <!-- window action -->
    <record id="product_brand_action" model="ir.actions.act_window">
        <field name="name">Marca del producto</field>
        <field name="res_model">product.brand</field>
        <field name="view_mode">list</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Click en nuevo para agregar nuevos registros</p>
        </field>
    </record>

    <!-- menu -->
    <menuitem
        id="product_brand_menu"
        name="Marca del producto"
        action="pharmacy_core_cross.product_brand_action"
        parent="stock.menu_product_in_config_stock"
        sequence="3"
    />

</odoo>
