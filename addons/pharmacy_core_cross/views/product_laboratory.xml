<odoo>

    <!-- list view -->
    <record id="product_laboratory_list" model="ir.ui.view">
        <field name="name">product.laboratory.list</field>
        <field name="model">product.laboratory</field>
        <field name="arch" type="xml">
            <list editable="top" sample="1">
                <field name="name" required="1"/>
                <field name="code"/>
            </list>
        </field>
    </record>

    <!-- window action -->
    <record id="product_laboratory_action" model="ir.actions.act_window">
        <field name="name">Laboratorio del producto</field>
        <field name="res_model">product.laboratory</field>
        <field name="view_mode">list</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Click en nuevo para agregar nuevos registros</p>
        </field>
    </record>

    <!-- menu -->
    <menuitem
        id="product_laboratory_menu"
        name="Laboratorio del producto"
        action="pharmacy_core_cross.product_laboratory_action"
        parent="stock.menu_product_in_config_stock"
        sequence="4"
    />

</odoo>
