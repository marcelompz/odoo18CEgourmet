<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- SEARCH VIEW -->
    <record id="view_prospecting_lead_search" model="ir.ui.view">
        <field name="name">prospecting.lead.search</field>
        <field name="model">prospecting.lead</field>
        <field name="arch" type="xml">
            <search string="Search Leads">
                <field name="name"/>
                <field name="keyword" filter_domain="[('campaign_id.keyword', 'ilike', self)]"/>
                <filter string="Has Website" name="has_website" domain="[('has_website', '=', True)]"/>
                <filter string="High Rating (>4.0)" name="high_rating" domain="[('rating', '>', 4.0)]"/>
                <group expand="0" string="Group By">
                    <filter string="Campaign" name="group_campaign" context="{'group_by': 'campaign_id'}"/>
                    <filter string="Tech Stack" name="group_tech" context="{'group_by': 'tech_stack'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_prospecting_lead_form" model="ir.ui.view">
        <field name="name">prospecting.lead.form</field>
        <field name="model">prospecting.lead</field>
        <field name="arch" type="xml">
            <form string="Lead">
                <header>
                    <button name="action_fetch_details" string="Fetch Google Details" type="object" class="btn-secondary"/>
                    <button name="action_scrape_website" string="Scrape Website" type="object" class="btn-secondary" invisible="not website"/>
                    <button name="action_generate_demo" string="Generate Demo Website" type="object" class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Business Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="campaign_id"/>
                            <field name="address"/>
                            <field name="place_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="rating" widget="priority"/>
                            <field name="user_ratings_total"/>
                            <field name="website" widget="url"/>
                            <field name="phone" widget="phone"/>
                            <field name="email" widget="email"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Tech &amp; Social">
                            <group>
                                <field name="has_website"/>
                                <field name="tech_stack"/>
                                <field name="social_links"/>
                            </group>
                        </page>
                        <page string="Demo Page">
                            <group>
                                <field name="demo_page_url" widget="url"/>
                            </group>
                            <field name="demo_html_content" readonly="1" options="{'collaborative': false, 'resizable': false}"/>
                        </page>
                        <page string="Raw Data">
                            <field name="json_data"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- TREE VIEW -->
    <record id="view_prospecting_lead_tree" model="ir.ui.view">
        <field name="name">prospecting.lead.tree</field>
        <field name="model">prospecting.lead</field>
        <field name="arch" type="xml">
            <list string="Leads" decoration-success="has_website">
                <field name="name"/>
                <field name="address"/>
                <field name="rating" widget="priority" optional="show"/>
                <field name="user_ratings_total" optional="show"/>
                <field name="website" widget="url"/>
                <field name="tech_stack" optional="hide"/>
                <field name="has_website" column_invisible="True"/>
                <button name="action_generate_demo" string="Demo" type="object" icon="fa-magic"/>
            </list>
        </field>
    </record>

</odoo>
