<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Wizard form view - Configuration -->
        <record id="view_cleanup_revert_wizard_form" model="ir.ui.view">
            <field name="name">cleanup.revert.wizard.form</field>
            <field name="model">cleanup.revert.wizard</field>
            <field name="arch" type="xml">
                <form string="Revert Cleanup">
                    <sheet>
                        <div invisible="[('state', '!=', 'config')]">
                            <group>
                                <group>
                                    <field name="log_id" readonly="1"/>
                                </group>
                                <group>
                                    <field name="revert_type"/>
                                    <field name="revert_action"/>
                                </group>
                            </group>
                            <footer>
                                <button name="action_revert" type="object" string="Continue" class="btn-primary"/>
                                <button name="action_cancel" type="object" string="Cancel" class="btn-secondary"/>
                            </footer>
                        </div>
                        
                        <div invisible="[('state', '!=', 'selection')]">
                            <group string="Select lines to revert">
                                <field name="line_ids" nolabel="1">
                                    <list>
                                        <field name="selected" widget="boolean_toggle"/>
                                        <field name="model_name"/>
                                        <field name="record_name"/>
                                        <field name="action_type"/>
                                    </list>
                                </field>
                            </group>
                            <footer>
                                <button name="action_revert" type="object" string="Revert Selected" class="btn-primary"/>
                                <button name="action_cancel" type="object" string="Cancel" class="btn-secondary"/>
                            </footer>
                        </div>
                        
                        <div invisible="[('state', '!=', 'results')]">
                            <group string="Revert Results">
                                <group>
                                    <div class="alert alert-success">
                                        <strong>Revert completed</strong>
                                        <div>Lines processed: <field name="lines_processed"/></div>
                                        <div>Lines reverted: <field name="lines_reverted"/></div>
                                        <div>Lines failed: <field name="lines_failed"/></div>
                                    </div>
                                    <div invisible="[('error_log', '=', False)]" class="alert alert-danger">
                                        <strong>Errors:</strong>
                                        <pre><field name="error_log"/></pre>
                                    </div>
                                </group>
                            </group>
                            <footer>
                                <button name="action_cancel" type="object" string="Close" class="btn-secondary"/>
                            </footer>
                        </div>
                    </sheet>
                </form>
            </field>
        </record>
        
        <!-- Wizard action -->
        <record id="action_cleanup_revert_wizard" model="ir.actions.act_window">
            <field name="name">Revert Cleanup</field>
            <field name="res_model">cleanup.revert.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
    </data>
</odoo>