<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Wizard form view -->
        <record id="view_cleanup_pos_tax_wizard_form" model="ir.ui.view">
            <field name="name">cleanup.pos.tax.wizard.form</field>
            <field name="model">cleanup.pos.tax.wizard</field>
            <field name="arch" type="xml">
                <form string="POS Tax Correction" class="o_cleanup_wizard">
                    <sheet>
                        <div invisible="[('state', '!=', 'config')]" class="oe_cleanup_config_step">
                            <group string="Configuration">
                                <group>
                                    <field name="config_id" widget="selection" options="{'no_create': True, 'no_open': True}" required="1"/>
                                </group>
                                <group>
                                    <field name="pos_tax_action" required="1"/>
                                    <field name="pos_date_from"/>
                                    <field name="pos_date_to"/>
                                </group>
                            </group>
                            
                            <footer>
                                <button name="action_detect_issues" type="object" string="Detect Issues" class="btn-primary"/>
                                <button name="action_cancel" type="object" string="Cancel" class="btn-secondary"/>
                            </footer>
                        </div>
                        
                        <div invisible="[('state', '!=', 'validation')]" class="oe_cleanup_validation_step">
                            <group string="Detection Results">
                                <group>
                                    <div class="alert alert-info">
                                        <strong>Total Lines Detected:</strong>
                                        <field name="total_lines_detected" widget="statinfo"/>
                                    </div>
                                </group>
                                <group>
                                    <div class="alert alert-warning">
                                        <strong>Missing Taxes:</strong>
                                        <field name="missing_tax_count" widget="statinfo"/>
                                    </div>
                                    <div class="alert alert-warning">
                                        <strong>Incorrect Taxes:</strong>
                                        <field name="incorrect_tax_count" widget="statinfo"/>
                                    </div>
                                    <div class="alert alert-warning">
                                        <strong>Extra Taxes:</strong>
                                        <field name="extra_tax_count" widget="statinfo"/>
                                    </div>
                                </group>
                            </group>
                            
                            <group string="Validation Actions">
                                <div class="oe_button_box">
                                    <button name="action_select_all" type="object" string="Select All" class="btn-secondary"/>
                                    <button name="action_deselect_all" type="object" string="Deselect All" class="btn-secondary"/>
                                    <button name="action_calculate_totals" type="object" string="Calculate Totals" class="btn-secondary"/>
                                </div>
                            </group>
                            
                            <group string="Lines to Validate">
                                <field name="validation_line_ids" nolabel="1">
                                    <list editable="bottom" string="Validation Lines">
                                        <field name="selected" invisible="1"/>
                                        <field name="order_id" string="Order" readonly="1"/>
                                        <field name="product_id" string="Product" readonly="1"/>
                                        <field name="discrepancy_type" string="Issue Type" readonly="1"/>
                                        <field name="current_tax_ids" widget="many2many_tags" string="Current Taxes" readonly="1"/>
                                        <field name="expected_tax_ids" widget="many2many_tags" string="Expected Taxes" readonly="1"/>
                                        <field name="price_subtotal" string="Subtotal" readonly="1"/>
                                        <field name="current_total" string="Current Total" readonly="1"/>
                                        <field name="calculated_total" string="Calculated Total" readonly="1"/>
                                        <field name="difference" string="Difference" readonly="1" decoration-danger="difference &lt; 0" decoration-success="difference &gt; 0"/>
                                        <field name="action" string="Action"/>
                                        <field name="status" string="Status" invisible="1"/>
                                        <button name="action_view_line" type="object" string="View" class="btn-link"/>
                                        <button name="action_view_order" type="object" string="Order" class="btn-link"/>
                                    </list>
                                </field>
                            </group>
                            
                            <footer>
                                <button name="action_execute_corrections" type="object" string="Execute Corrections" class="btn-primary"/>
                                <button name="action_back_to_config" type="object" string="Back" class="btn-secondary"/>
                                <button name="action_cancel" type="object" string="Cancel" class="btn-secondary"/>
                            </footer>
                        </div>
                        
                        <div invisible="[('state', '!=', 'results')]" class="oe_cleanup_results_step">
                            <group string="Execution Results">
                                <group>
                                    <div class="alert alert-success">
                                        <strong>Lines Processed:</strong>
                                        <field name="lines_processed" widget="statinfo"/>
                                    </div>
                                    <div class="alert alert-success">
                                        <strong>Lines Corrected:</strong>
                                        <field name="lines_corrected" widget="statinfo"/>
                                    </div>
                                    <div class="alert alert-danger">
                                        <strong>Lines Failed:</strong>
                                        <field name="lines_failed" widget="statinfo"/>
                                    </div>
                                </group>
                            </group>
                            
                            <group string="Error Log">
                                <field name="error_log" nolabel="1" readonly="1" widget="text"/>
                            </group>
                            
                            <footer>
                                <button name="action_view_log" type="object" string="View Log" class="btn-primary"/>
                                <button name="action_back_to_config" type="object" string="New Correction" class="btn-secondary"/>
                                <button name="action_cancel" type="object" string="Close" class="btn-secondary"/>
                            </footer>
                        </div>
                    </sheet>
                </form>
            </field>
        </record>
        
        <!-- Wizard action -->
        <record id="action_cleanup_pos_tax_wizard" model="ir.actions.act_window">
            <field name="name">Validate POS Tax Corrections</field>
            <field name="res_model">cleanup.pos.tax.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="binding_model_id" ref="model_cleanup_config"/>
            <field name="binding_type">action</field>
        </record>
    </data>
</odoo>