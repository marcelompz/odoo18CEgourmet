<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Cron job for automatic cleanup execution -->
        <record id="ir_cron_cleanup_execute" model="ir.cron">
            <field name="name">Cleanup: Execute Scheduled Cleanup</field>
            <field name="model_id" ref="model_cleanup_config"/>
            <field name="active">False</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="doall">False</field>
            <field name="priority">10</field>
            <field name="code">model._cron_execute_cleanup()</field>
        </record>
    </data>
</odoo>