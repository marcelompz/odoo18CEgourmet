<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Sequence for cleanup log references -->
        <record id="seq_cleanup_log" model="ir.sequence">
            <field name="name">Cleanup Log Reference</field>
            <field name="code">cleanup.log</field>
            <field name="prefix">CLEAN/%(year)s/%(month)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>