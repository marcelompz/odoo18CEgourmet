<odoo>

    <!-- Acción para recalcular márgenes en POS Orders -->
    <record id="action_recalculate_pos_order_margins" model="ir.actions.server">
        <field name="name">Recalcular Márgenes (con Impuestos)</field>
        <field name="model_id" ref="point_of_sale.model_pos_order"/>
        <field name="binding_model_id" ref="point_of_sale.model_pos_order"/>
        <field name="state">code</field>
        <field name="code">
            if records:
                records.action_recalculate_margins()
        </field>
    </record>

</odoo>
