<odoo>

    <!-- form view -->

    <record id="stock_landed_cost_inherit_form" model="ir.ui.view">
        <field name="name">stock.landed.cost.inherit.form</field>
        <field name="model">stock.landed.cost</field>
        <field name="inherit_id" ref="stock_landed_costs.view_stock_landed_cost_form" />
        <field name="arch" type="xml">

            <xpath expr="//notebook//page[@name='additional_costs']//field[@name='cost_lines']//list" position="replace">
                <list string="Líneas de costo" editable="bottom">
                    <field name="product_id"
                        domain="[('landed_cost_ok', '=', True)]"
                        context="{'default_landed_cost_ok': True, 'default_type': 'service'}"/>
                    <field name="name"/>
                    <field name="account_id" column_invisible="True" options="{'no_create': True}"/>
                    <field name="split_method" column_invisible="True"/>
                    <field name="product_landed_cost_percentage" widget="percentage"/>
                    <field name="price_unit" readonly="True"/>
                    <field name="product_price_real"/>
                    <field name="currency_id" column_invisible="True"/>
                    <field name="supplier_id" options="{'no_create': True, 'no_open': True}"/>
                    <field name="bill_reference"/>
                    <button 
                        name="action_create_bill" 
                        type="object" 
                        string=" Crear factura"
                        icon="fa-file-text"
                        invisible="move_id"
                    />
                    <field name="state" column_invisible="1"/>
                    <field name="move_id" column_invisible="1"/>
                </list>
            </xpath>

        </field>
    </record>

</odoo>
