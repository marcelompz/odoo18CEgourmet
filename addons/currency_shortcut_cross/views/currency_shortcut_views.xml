<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Window Action to View the List of Currencies -->
        <record id="action_view_currencies_visible_shortcut" model="ir.actions.act_window">
            <field name="name">Monedas</field>
            <field name="res_model">res.currency</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'create': False}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Crea una nueva moneda
                </p><p>
                    Define y gestiona las monedas disponibles en tu sistema, así como sus tasas de cambio.
                </p>
            </field>
        </record>

        <!-- Use a top-level menu or existing base menu to avoid 'account' dependency issues -->
         <!-- For safety, we'll put it under Technical Settings first, OR create a simple root menu -->
         <!-- Let's use base.menu_custom which usually exists or base.menu_automation -->
         <!-- Better: Create a new Top Menu "Currencies" to be super safe and visible -->
         
         <menuitem
            id="menu_currencies_shortcut_root"
            name="Monedas"
            web_icon="currency_shortcut_cross,static/description/currency.png"
            sequence="50"/>

        <menuitem
            id="menu_view_currencies_visible_shortcut"
            name="Monedas"
            action="action_view_currencies_visible_shortcut"
            parent="menu_currencies_shortcut_root"
            sequence="100"
            groups="base.group_multi_currency"
        />
    </data>
</odoo>
