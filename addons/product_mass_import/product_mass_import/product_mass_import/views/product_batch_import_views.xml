<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Batch Import Form View -->
    <record id="product_batch_import_view_form" model="ir.ui.view">
        <field name="name">product.batch.import.form</field>
        <field name="model">product.batch.import</field>
        <field name="arch" type="xml">
            <form string="Importación en Lote">
                <header>
                    <button name="action_validate" type="object" string="Validar"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_confirm" type="object" string="Confirmar"
                            class="btn-primary" invisible="state != 'validated'"/>
                    <button name="action_cancel" type="object" string="Cancelar"
                            class="btn-secondary" invisible="state != 'draft'"/>
                    <button name="action_reset_draft" type="object" string="Volver a Borrador"
                            class="btn-secondary" invisible="state in ['done', 'cancel']"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,validated,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_add_line" type="object"
                                class="oe_stat_button" icon="fa-plus"
                                string="Agregar Línea"
                                invisible="state != 'draft'"/>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="location_id" readonly="state != 'draft'"/>
                            <field name="company_id" groups="base.group_multi_company"
                                   readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="product_count" string="Total"/>
                            <field name="valid_count" string="Válidos"/>
                            <field name="invalid_count" string="Con Errores"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Productos" name="products">
                            <field name="line_ids">
                                <list editable="bottom" decoration-danger="error_message != False"
                                      decoration-success="is_valid == True and product_id != False">
                                    <field name="sequence" widget="handle"/>
                                    <field name="default_code" required="1"/>
                                    <field name="name" required="1"/>
                                    <field name="pos_description"/>
                                    <field name="barcode"/>
                                    <field name="categ_name"/>
                                    <field name="pos_categ_name"/>
                                    <field name="product_type"/>
                                    <field name="tracking"/>
                                    <field name="available_in_pos"/>
                                    <field name="list_price"/>
                                    <field name="standard_price"/>
                                    <field name="qty_on_hand"/>
                                    <field name="is_valid" column_invisible="1"/>
                                    <field name="error_message" optional="show"/>
                                    <field name="product_id" readonly="1" optional="show"/>
                                    <button name="action_delete" type="object" string="Eliminar"
                                            class="btn-danger" icon="fa-trash"
                                            invisible="parent.state != 'draft'"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Batch Import Tree View -->
    <record id="product_batch_import_view_tree" model="ir.ui.view">
        <field name="name">product.batch.import.tree</field>
        <field name="model">product.batch.import</field>
        <field name="arch" type="xml">
            <list string="Importaciones en Lote">
                <field name="name"/>
                <field name="location_id"/>
                <field name="product_count"/>
                <field name="valid_count"/>
                <field name="invalid_count"/>
                <field name="state"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <!-- Batch Import Search View -->
    <record id="product_batch_import_view_search" model="ir.ui.view">
        <field name="name">product.batch.import.search</field>
        <field name="model">product.batch.import</field>
        <field name="arch" type="xml">
            <search string="Buscar Importaciones">
                <field name="name"/>
                <separator/>
                <filter name="draft" string="Borrador" domain="[('state', '=', 'draft')]"/>
                <filter name="validated" string="Validado" domain="[('state', '=', 'validated')]"/>
                <filter name="done" string="Completado" domain="[('state', '=', 'done')]"/>
            </search>
        </field>
    </record>

    <!-- Batch Import Action -->
    <record id="product_batch_import_action" model="ir.actions.act_window">
        <field name="name">Importación en Lote de Productos</field>
        <field name="res_model">product.batch.import</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="product_batch_import_view_search"/>
        <field name="context">{'default_name': 'Nuevo'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crear primera importación en lote
            </p>
            <p>
                Cree productos manualmente con validación previa y asignación de stock inicial.
            </p>
        </field>
    </record>

</odoo>
