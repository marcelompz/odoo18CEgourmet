<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_excel_recipe_import_wizard" model="ir.ui.view">
        <field name="name">excel.recipe.import.wizard.form</field>
        <field name="model">excel.recipe.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Importar Recetas">
                <group>
                    <div class="alert alert-info" role="alert">
                        Por favor, descargue la plantilla, complétela y súbala aquí para importar los productos y recetas a los módulos de Fabricación (MRP) y POS BoM.
                    </div>
                </group>
                <group>
                    <group>
                        <field name="import_type"/>
                    </group>
                    <group>
                        <field name="import_file" filename="import_filename" />
                        <field name="import_filename" invisible="1"/>
                    </group>
                </group>
                <footer>
                    <button name="action_validate" string="Validar Archivo" type="object" class="btn-info" style="background-color: #17a2b8; color: white;"/>
                    <button name="action_import" string="Importar" type="object" class="btn-primary"/>
                    <button name="action_download_template" string="Descargar Plantilla Base" type="object" class="btn-secondary"/>
                    <button name="action_export_missing_pos_bom" string="Exportar Faltantes (POS BoM)" type="object" class="btn-secondary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_excel_recipe_import_wizard" model="ir.actions.act_window">
        <field name="name">Importar Recetas Excel</field>
        <field name="res_model">excel.recipe.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_excel_recipe_root" name="Importador Excel" sequence="50"/>
    <menuitem id="menu_excel_recipe_import_main"
              name="Importar Recetas"
              parent="menu_excel_recipe_root"
              action="action_excel_recipe_import_wizard"
              sequence="10"/>

    <menuitem id="menu_excel_recipe_import_mrp"
              name="Importador Excel"
              parent="mrp.menu_mrp_root"
              action="action_excel_recipe_import_wizard"
              sequence="50"/>

    <menuitem id="menu_excel_recipe_import_pos"
              name="Importador Excel"
              parent="point_of_sale.menu_point_root"
              action="action_excel_recipe_import_wizard"
              sequence="50"/>
</odoo>
