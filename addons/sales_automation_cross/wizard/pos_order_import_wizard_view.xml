<odoo>
    <record id="view_pos_import_wizard_form" model="ir.ui.view">
        <field name="name">pos.import.wizard.form</field>
        <field name="model">pos.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Importar Histórico de Pedidos PDV">
                <sheet>
                    <div class="alert alert-info" role="alert" invisible="line_ids">
                        <i class="fa fa-info-circle"/> 
                        <strong>Paso 1:</strong> Sube tu archivo y presiona <strong>"Detectar Columnas"</strong>.
                    </div>
                    
                    <group>
                        <group>
                            <field name="file" filename="file_name" string="Archivo Excel/CSV"/>
                            <field name="file_name" invisible="1"/>
                            <field name="session_id" options="{'no_create': True}" string="Sesión de Destino"/>
                        </group>
                        <group>
                            <field name="is_excel" invisible="1"/>
                            <field name="delimiter" invisible="is_excel" string="Separador CSV"/>
                            <button name="action_load_columns" 
                                    string="Detectar Columnas" 
                                    type="object" 
                                    class="btn-secondary" 
                                    icon="fa-refresh"
                                    invisible="not file"/>
                        </group>
                    </group>
                    
                    <group string="Vinculación de Campos" invisible="not line_ids">
                        <field name="line_ids" nolabel="1">
                            <list editable="bottom" create="0" delete="0">
                                <field name="column_name"/>
                                <field name="odoo_field" decoration-bf="odoo_field != 'ignore'" decoration-info="odoo_field != 'ignore'"/>
                            </list>
                        </field>
                    </group>
                </sheet>
                <footer>
                    <button string="Importar Datos" name="action_import" type="object" class="btn-primary" invisible="not line_ids"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_pos_import_wizard" model="ir.actions.act_window">
        <field name="name">Importar Histórico</field>
        <field name="res_model">pos.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Adicionar al menú de Órdenes de POS -->
    <record id="pos_order_import_action_binding" model="ir.actions.server">
        <field name="name">Importar Histórico (Excel/CSV)</field>
        <field name="model_id" ref="point_of_sale.model_pos_order"/>
        <field name="binding_model_id" ref="point_of_sale.model_pos_order"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            action = env.ref('sales_automation_cross.action_pos_import_wizard').read()[0]
        </field>
    </record>
</odoo>
