<odoo>
    <data>
        <record id="sale_order_action_confirm_invoice_pay_deliver" model="ir.actions.server">
            <field name="name">Confirmar, Facturar, Pagar y Entregar</field>
            <field name="model_id" ref="sale.model_sale_order"/>
            <field name="binding_model_id" ref="sale.model_sale_order"/>
            <field name="state">code</field>
            <field name="code">
                action = records.action_confirm_invoice_pay_deliver()
            </field>
        </record>

        <record id="sale_order_action_confirm_invoice_pay_deliver_menu" model="ir.actions.act_window">
            <field name="name">Confirmar, Facturar, Pagar y Entregar</field>
            <field name="res_model">sale.order</field>
            <field name="binding_model_id" ref="sale.model_sale_order"/>
            <field name="view_mode">tree,form</field>
            <field name="domain">[('state', 'in', ['draft', 'sent'])]</field>
            <field name="context">{'default_state': 'draft'}</field>
            <field name="groups_id" eval="[(4, ref('sales_team.group_sale_manager'))]"/>
        </record>
    </data>
</odoo>
