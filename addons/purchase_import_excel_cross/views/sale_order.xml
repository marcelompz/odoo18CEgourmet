<odoo>

    <!-- form view -->
    <record id="sale_order_inherit_form" model="ir.ui.view">
        <field name="name">sale.order.inherit.form</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form" />
        <field name="arch" type="xml">

            <xpath expr="//notebook//page[@name='order_lines']//field[@name='order_line']" position="before">
                <button name="action_open_import_wizard" type="object" string="IMPORTAR DESDE EXCEL" class="oe_highlight oe_right"
                    help="Importa líneas de pedido de venta desde un archivo Excel." invisible ="state != 'draft'"/>
            </xpath>
        
        </field>
    </record>

</odoo>
