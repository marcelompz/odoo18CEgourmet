<odoo>

    <!-- form view -->

    <record id="stock_picking_inherit_form" model="ir.ui.view">
        <field name="name">stock.picking.inherit.form</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form" />
        <field name="arch" type="xml">

            <xpath expr="//notebook/page/field[@name='move_ids_without_package']" position="before">
                <button name="action_open_import_wizard" type="object" string="IMPORTAR DESDE EXCEL" class="oe_highlight oe_right"
                    help="Importa líneas de translados desde un archivo Excel." invisible ="state != 'draft'"/>
            </xpath>
        
        </field>
    </record>

</odoo>
