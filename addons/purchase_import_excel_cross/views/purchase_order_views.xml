<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Botón "Importar desde Excel" en el formulario de Órdenes de Compra -->
    <record id="view_purchase_order_form_import_btn" model="ir.ui.view">
        <field name="name">purchase.order.form.import.excel.btn</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_open_import_excel_wizard"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-file-excel-o"
                        groups="purchase.group_purchase_user"
                        invisible="state not in ('draft', 'sent')">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Importar</span>
                        <span class="o_stat_text">Excel</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>

</odoo>
