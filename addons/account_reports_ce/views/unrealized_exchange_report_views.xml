<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_unrealized_exchange_wizard_ce_form" model="ir.ui.view">
        <field name="name">unrealized.exchange.wizard.ce.form</field>
        <field name="model">unrealized.exchange.wizard.ce</field>
        <field name="arch" type="xml">
            <form string="Ganancias/Pérdidas no Realizadas">
                <group>
                    <group>
                        <field name="date"/>
                        <field name="transaction_type"/>
                    </group>
                    <group>
                        <field name="company_id" groups="base.group_multi_company"/>
                        <field name="currency_id"/>
                        <field name="company_currency_id" invisible="1"/>
                    </group>
                </group>
                <footer>
                    <button name="action_generate_report" string="Generar Reporte" type="object" class="btn-primary"/>
                    <button special="cancel" string="Cancelar" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_unrealized_exchange_wizard_ce" model="ir.actions.act_window">
        <field name="name">Ganancias y Pérdidas no Realizadas</field>
        <field name="res_model">unrealized.exchange.wizard.ce</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_account_unrealized_exchange_ce"
              name="Ganancias/Pérdidas no Realizadas"
              parent="menu_account_reports_management"
              action="action_unrealized_exchange_wizard_ce"
              sequence="50"/>

    <!-- Vistas del resultado del reporte -->
    <record id="view_unrealized_exchange_report_line_ce_tree" model="ir.ui.view">
        <field name="name">unrealized.exchange.report.line.ce.list</field>
        <field name="model">unrealized.exchange.report.line.ce</field>
        <field name="arch" type="xml">
            <list string="Detalle de Transacciones" create="0" edit="0" delete="0">
                <field name="date"/>
                <field name="move_line_id"/>
                <field name="transaction_type"/>
                <field name="currency_id"/>
                <field name="amount_currency" sum="Total Divisa"/>
                <field name="original_rate" digits="[12,6]"/>
                <field name="amount_company_original" sum="Total Original"/>
                <field name="current_rate" digits="[12,6]"/>
                <field name="amount_company_current" sum="Total Actualizado"/>
                <field name="unrealized_gain_loss" sum="Ganancia/Pérdida Total" widget="monetary" decoration-danger="unrealized_gain_loss &lt; 0" decoration-success="unrealized_gain_loss &gt; 0"/>
                <field name="company_currency_id" column_invisible="True"/>
            </list>
        </field>
    </record>

    <record id="view_unrealized_exchange_report_line_ce_pivot" model="ir.ui.view">
        <field name="name">unrealized.exchange.report.line.ce.pivot</field>
        <field name="model">unrealized.exchange.report.line.ce</field>
        <field name="arch" type="xml">
            <pivot string="Análisis Pivot Ganancias/Pérdidas no Realizadas" disable_linking="True">
                <field name="currency_id" type="row"/>
                <field name="transaction_type" type="col"/>
                <field name="amount_currency" type="measure"/>
                <field name="amount_company_original" type="measure"/>
                <field name="amount_company_current" type="measure"/>
                <field name="unrealized_gain_loss" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_unrealized_exchange_report_line_ce_graph" model="ir.ui.view">
        <field name="name">unrealized.exchange.report.line.ce.graph</field>
        <field name="model">unrealized.exchange.report.line.ce</field>
        <field name="arch" type="xml">
            <graph string="Gráfico Ganancias/Pérdidas no Realizadas" type="bar">
                <field name="currency_id"/>
                <field name="unrealized_gain_loss" type="measure"/>
            </graph>
        </field>
    </record>

</odoo>
