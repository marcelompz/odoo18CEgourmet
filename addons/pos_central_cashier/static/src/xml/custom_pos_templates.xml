<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!-- Botón en Actionpad (PDV Mostrador) -->
    <t t-name="pos_central_cashier.ActionpadWidget" t-inherit="point_of_sale.ActionpadWidget" t-inherit-mode="extension" owl="1">
        <xpath expr="//button[contains(@class, 'pay')]" position="before">
            <t t-if="pos.config.is_counter_pos">
                <button class="pay btn btn-warning btn-lg py-3 d-flex align-items-center justify-content-center flex-fill"
                    t-on-click="() => env.services.pos.markOrderPending()">
                    <div class="pay-circle" style="background: orange;">
                        <i class="fa fa-print" />
                    </div>
                    <span>Precuenta y Pendiente</span>
                </button>
            </t>
        </xpath>
    </t>

    <!-- Botón de Búsqueda (PDV Caja) en Navbar -->
    <t t-name="pos_central_cashier.Navbar" t-inherit="point_of_sale.Navbar" t-inherit-mode="extension" owl="1">
        <xpath expr="//div[contains(@class, 'pos-rightheader')]" position="inside">
            <t t-if="pos.config.is_central_cashier">
                <button class="btn btn-light btn-lg lh-lg" t-on-click="() => env.services.pos.openPendingOrdersDialog()">
                    <i class="fa fa-search"/> Buscar Órdenes
                </button>
            </t>
        </xpath>
    </t>

    <!-- Screen para buscar órdenes -->
    <t t-name="pos_central_cashier.PendingOrdersDialog" owl="1">
        <div class="pos-screen d-flex flex-column h-100 bg-view">
            <div class="screen-header d-flex align-items-center gap-2 p-2 bg-white border-bottom">
                <button class="btn btn-light" t-on-click="() => pos.showScreen('ProductScreen')">
                    <i class="fa fa-arrow-left"/> Volver
                </button>
                <h4 class="mb-0 ms-2">Buscar Órdenes Pendientes</h4>
            </div>
            <div class="screen-content flex-grow-1 p-3 overflow-auto">
                <div class="mb-3">
                    <input type="text" class="form-control form-control-lg"
                           t-att-value="state.searchQuery"
                           t-on-input="onSearchInput"
                           placeholder="Referencia o Cliente..."/>
                </div>
                <div t-if="state.error" class="alert alert-danger mb-3">
                    <t t-esc="state.error"/>
                </div>
                <div t-if="state.loading" class="text-center py-4">
                    <i class="fa fa-spinner fa-spin fa-2x"/>
                    <p>Cargando...</p>
                </div>
                <div class="orders-list" t-else="">
                    <div t-if="state.orders.length === 0" class="text-center text-muted py-4">
                        No se encontraron órdenes pendientes
                    </div>
                    <t t-foreach="state.orders" t-as="order" t-key="order.id">
                        <div class="order-item card mb-2 border" t-on-click="() => this.loadOrder(order.id)" style="cursor: pointer;">
                            <div class="card-body d-flex justify-content-between align-items-center">
                                <div>
                                    <strong><t t-esc="order.precuenta_ref" /></strong>
                                    <br/>
                                    <small class="text-muted"><t t-esc="order.partner_name" /></small>
                                </div>
                                <div class="text-end">
                                    <span class="fw-bold" t-esc="pos.currency.format(order.amount_total)" />
                                </div>
                            </div>
                        </div>
                    </t>
                </div>
            </div>
        </div>
    </t>

</templates>
