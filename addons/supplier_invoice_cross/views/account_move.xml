<odoo>

    <!-- form view -->

    <record id="account_move_inherit_form" model="ir.ui.view">
        <field name="name">account.move.inherit.form</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="electronic_invoice_cross.view_move_form_inherit" />
        <field name="arch" type="xml">

            <!-- numero de factura -->
            <xpath expr="//field[@name='invoice_number']" position="replace"/>
            <!-- <xpath expr="//field[@name='invoice_number']" position="replace"/> -->

            <!-- timbrado compra -->
            <xpath expr="//field[@name='fiscal_document']" position="after">
                <field name="in_invoice_stamped" invisible="move_type != 'in_invoice'" readonly="state != 'draft'"/>
                <field name="invoice_number" invisible="move_type != 'out_invoice'" readonly="not l10n_py_enabled_invoice_number or state != 'draft'"/>
                <field name="invoice_number" invisible="move_type != 'in_invoice'" readonly="state != 'draft'"/>
            </xpath>

            <!-- referencia de factura -->
            <xpath expr="//field[@name='ref']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>
        
        </field>
    </record>

    <!-- menu root -->

    <menuitem
        id="open_account_action_move_in_invoice_type"
        name="Factura Proveedor"
        action="account.action_move_in_invoice_type"
        sequence="50"
        web_icon="supplier_invoice_cross,static/description/supplier-purchase.png"
    />

</odoo>
