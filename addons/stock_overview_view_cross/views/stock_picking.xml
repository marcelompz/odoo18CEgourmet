<odoo>

    <!-- windows actions -->
    <record id="stock_picking_action_kanban_inherit" model="ir.actions.act_window">
        <field name="name">All Transfers</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">kanban,list,form,calendar</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No transfers found. Let's create one!
            </p>
        </field>
    </record>
    
    <record id="stock.stock_picking_action_picking_type" model="ir.actions.act_window">
        <field name="name">All Transfers</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">kanban,list,form,calendar</field>
    </record>

    <record id="stock.action_picking_tree_ready" model="ir.actions.act_window">
        <field name="name">Pickings Ready</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">kanban,list,form,calendar</field>
    </record>

    <record id="stock.action_picking_tree_late" model="ir.actions.act_window">
        <field name="name">Pickings Late</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">kanban,list,form,calendar</field>
    </record>

    <record id="stock.action_get_picking_type_ready_moves" model="ir.actions.act_window">
        <field name="name">Operations</field>
        <field name="res_model">stock.move</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <record id="action_picking_view_form_in_modal" model="ir.actions.act_window">
        <field name="name">Ver Traslado</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="stock.view_picking_form"/>
        <field name="target">new</field>
    </record>

    <!-- kanban view -->
    <record id="stock_picking_inherit_kanban" model="ir.ui.view">
        <field name="name">stock.picking.inherit.kanban</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.stock_picking_kanban" />
        <field name="arch" type="xml">

            <xpath expr="//kanban" position="attributes">
                <attribute name="default_group_by">state</attribute>
                <attribute name="group_create">false</attribute>
                <attribute name="group_delete">false</attribute>
                <attribute name="quick_create">false</attribute>
                <attribute name="default_order">id desc</attribute>
            </xpath>

            <xpath expr="//kanban//progressbar" position="replace"/>

            <xpath expr="//kanban//field[@name='picking_type_id']" position="after">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="user_id"/>
                <field name="scheduled_date"/>
                <field name="note"/>
                <field name="origin"/>
            </xpath>

            <xpath expr="//kanban//templates//t[@t-name='card']" position="replace">
                <t t-name="card">
                    <div class="d-flex mb-1">
                        <div>
                            <span class="fw-bold">Cliente: </span>
                            <field name="partner_id"/>
                        </div>
                        <field name="state" widget="label_selection" options="{'classes': {'draft': 'default', 'cancel': 'danger', 'waiting': 'warning', 'confirmed': 'warning', 'done': 'success'}}" class="ms-auto"/>
                    </div>
                    <div class="d-flex">
                        <div>
                            <span class="fw-bold">Origen: </span>
                            <field name="origin"/>
                        </div>
                        <div class="ms-auto">
                            <span class="fw-bold">Pedido: </span>
                            <field name="name"/>
                        </div>
                    </div>
                    <div t-if="record.note.raw_value">
                        <span class="fw-bold">Nota: </span>
                        <field name="note"/>
                    </div>
                    <br/>
                    <footer class="pt-0">
                        <div class="d-flex">
                            <field name="activity_ids" widget="kanban_activity"/>
                            <field name="json_popover" nolabel="1" widget="stock_rescheduling_popover" invisible="not json_popover"/>
                        </div>
                        <div class="d-flex ms-auto mt-1 align-items-center">
                            <field name="scheduled_date"/>
                        </div>
                    </footer>
                    <div class="d-flex justify-content-between mt-2">
                        <button name="button_validate" type="object" string=" Validar" icon="fa-check-square-o" invisible="state in ['done', 'cancel']"/>
                        <button name="%(stock.action_report_delivery)d" type="action" string=" A4" icon="fa-print"/>
                    </div>
                </t>
            </xpath>
        
        </field>
    </record>

    <!-- form view -->
    <record id="stock_picking_inherit_form" model="ir.ui.view">
        <field name="name">stock.picking.inherit.form</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form" />
        <field name="arch" type="xml">

            <xpath expr="//notebook//page[@name='operations']//field[@name='move_ids_without_package']/list/field[@name='quantity']" position="attributes">
                <attribute name="decoration-danger">product_uom_qty and quantity != product_uom_qty and parent.state not in ['cancel']</attribute>
            </xpath>

        </field>
    </record>

    <!-- list view -->
    <record id="stock_picking_inherit_tree" model="ir.ui.view">
        <field name="name">stock.picking.inherit.tree</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.vpicktree" />
        <field name="arch" type="xml">

            <xpath expr="//list" position="attributes">
                <attribute name="default_order">id desc</attribute>
            </xpath>
        
        </field>
    </record>

</odoo>
