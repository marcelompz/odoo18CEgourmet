<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_financial_cross" model="ir.actions.report">
        <field name="name">Estado de Resultados</field>
        <field name="model">accounting.report.result.cross</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">accounting_reporte_cross.report_financial_template</field>
        <field name="report_file">accounting_reporte_cross.report_financial_template</field>
        <field name="print_report_name">'Reporte - %s' % (object.report_id.name)</field>
        <field name="binding_model_id" ref="model_accounting_report_result_cross"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_financial_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="text-center mb-4">
                            <h2><t t-esc="o.report_id.name"/></h2>
                            <h4>Desde: <t t-esc="o.date_from"/> Hasta: <t t-esc="o.date_to"/></h4>
                        </div>

                        <table class="table table-sm table-reports">
                            <thead>
                                <tr>
                                    <th>Descripción</th>
                                    <th class="text-end">Saldo</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="o.line_ids" t-as="line">
                                    <tr t-att-class="'fw-bold' if line.is_title or line.is_total else ''"
                                        t-att-style="'background-color: #f8f9fa;' if line.is_total else ''">
                                        <td>
                                            <span t-att-style="'padding-left: ' + str(line.level * 20) + 'px;'">
                                                <t t-esc="line.name"/>
                                            </span>
                                        </td>
                                        <td class="text-end">
                                            <t t-esc="line.balance" t-options='{"widget": "monetary", "display_currency": o.env.company.currency_id}'/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
