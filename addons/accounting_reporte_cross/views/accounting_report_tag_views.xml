<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_accounting_report_tag_tree" model="ir.ui.view">
        <field name="name">accounting.report.tag.cross.list</field>
        <field name="model">accounting.report.tag.cross</field>
        <field name="arch" type="xml">
            <list string="Etiquetas Regulatorias" editable="bottom">
                <field name="code"/>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_accounting_report_tag" model="ir.actions.act_window">
        <field name="name">Etiquetas Regulatorias</field>
        <field name="res_model">accounting.report.tag.cross</field>
        <field name="view_mode">list</field>
    </record>
</odoo>
