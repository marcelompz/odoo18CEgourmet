<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Report Definition Form -->
    <record id="view_accounting_report_form" model="ir.ui.view">
        <field name="name">accounting.report.cross.form</field>
        <field name="model">accounting.report.cross</field>
        <field name="arch" type="xml">
            <form string="Definición de Reporte">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="ej. Estado de Resultados"/></h1>
                    </div>
                    <notebook>
                        <page string="Líneas" name="lines">
                            <field name="line_ids">
                                <list string="Líneas del Reporte">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="code"/>
                                    <field name="type"/>
                                    <field name="parent_id"/>
                                </list>
                                <form>
                                    <group>
                                        <group>
                                            <field name="name"/>
                                            <field name="code"/>
                                            <field name="type"/>
                                            <field name="parent_id" domain="[('report_id', '=', parent.id)]"/>
                                        </group>
                                        <group>
                                            <field name="sequence"/>
                                            <field name="is_negative"/>
                                        </group>
                                    </group>
                                    <group string="Configuración" invisible="type == 'view'">
                                        <field name="account_type" 
                                               invisible="type not in ['accounts', 'accounts_tags']"/>
                                        <field name="account_ids" widget="many2many_tags" 
                                               invisible="type not in ['accounts', 'accounts_tags']"/>
                                        <field name="tag_ids" widget="many2many_tags"
                                               invisible="type not in ['tags', 'accounts_tags']"/>
                                        <field name="formula" invisible="type != 'formula'"
                                               placeholder="ej. #INGRESOS - #COSTOS"/>
                                    </group>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_accounting_report_tree" model="ir.ui.view">
        <field name="name">accounting.report.cross.list</field>
        <field name="model">accounting.report.cross</field>
        <field name="arch" type="xml">
            <list string="Reportes">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="action_accounting_report_definition" model="ir.actions.act_window">
        <field name="name">Definiciones de Reporte</field>
        <field name="res_model">accounting.report.cross</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
