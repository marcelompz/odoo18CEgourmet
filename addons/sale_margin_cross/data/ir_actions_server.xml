<odoo>

    <!-- Acción para recalcular márgenes en Sales Orders -->
    <record id="action_recalculate_sale_order_margins" model="ir.actions.server">
        <field name="name">Recalcular Márgenes (con Impuestos)</field>
        <field name="model_id" ref="sale.model_sale_order"/>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="state">code</field>
        <field name="code">
            if records:
                records.action_recalculate_margins()
        </field>
    </record>

</odoo>
