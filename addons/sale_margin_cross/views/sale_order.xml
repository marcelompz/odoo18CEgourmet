<odoo>

    <!-- list view -->
    <record id="sale_order_inherit_tree" model="ir.ui.view">
        <field name="name">sale.order.inherit.tree</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.sale_order_tree" />
        <field name="arch" type="xml">

            <xpath expr="//field[@name='amount_total']" position="after">
                <field name="margin" optional="hide" groups="sale_margin_cross.group_user_show_margin_cross"/>
                <field name="margin_percent" widget="percentage" optional="hide" groups="sale_margin_cross.group_user_show_margin_cross"/>
            </xpath>
        
        </field>
    </record>

    <!-- form view -->
    <record id="sale_order_inherit_form" model="ir.ui.view">
        <field name="name">sale.order.inherit.form</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale_margin.sale_margin_sale_order"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='margin']/ancestor::div[1]" position="attributes">
                <attribute name="groups">sale_margin_cross.group_user_show_margin_cross</attribute>
            </xpath>

        </field>
    </record>

    <!-- wizard view -->
    <record id="sale_order_line_margin_form_inherit_cross" model="ir.ui.view">
        <field name="name">sale.order.line.margin.form.inherit.cross</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale_margin.sale_margin_sale_order_line"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='order_line']/form//field[@name='purchase_price']" position="attributes">
                <attribute name="groups">sale_margin_cross.group_user_show_margin_cross</attribute>
            </xpath>

        </field>
    </record>

    <!-- sale order form view -->
    <record id="sale_order_line_tree_margin_inherit_cross" model="ir.ui.view">
        <field name="name">sale.order.line.tree.margin.inherit.cross</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale_margin.sale_margin_sale_order_line_form"/>
        <field name="arch" type="xml">
    
            <xpath expr="//field[@name='order_line']//field[@name='purchase_price']" position="attributes">
                <attribute name="groups">sale_margin_cross.group_user_show_margin_cross</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']//field[@name='margin']" position="attributes">
                <attribute name="groups">sale_margin_cross.group_user_show_margin_cross</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']//field[@name='margin_percent']" position="attributes">
                <attribute name="groups">sale_margin_cross.group_user_show_margin_cross</attribute>
            </xpath>
    
        </field>
    </record>

</odoo>
