<odoo>

    <!-- Vista Árbol -->
    <record id="audit_log_delete_tree_view" model="ir.ui.view">
        <field name="name">audit.log.delete.tree</field>
        <field name="model">audit.log.delete</field>
        <field name="arch" type="xml">
            <list create="false" edit="false" delete="false">
                <field name="deletion_date" string="Fecha"/>
                <field name="user_id" string="Usuario"/>
                <field name="model_name" string="Modelo"/>
                <field name="display_name" string="Registro Eliminado"/>
                <field name="res_id"/>
            </list>
        </field>
    </record>

    <!-- Vista Formulario -->
    <record id="audit_log_delete_form_view" model="ir.ui.view">
        <field name="name">audit.log.delete.form</field>
        <field name="model">audit.log.delete</field>
        <field name="arch" type="xml">
            <form create="false" edit="false" delete="false">
                <sheet>
                    <group>
                        <group>
                            <field name="deletion_date"/>
                            <field name="user_id"/>
                        </group>
                        <group>
                            <field name="model_name"/>
                            <field name="res_id"/>
                            <field name="display_name"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Datos Eliminados">
                            <!-- Usamos un campo de texto y lo llenamos con una función para que se vea bonito -->
                            <field name="data_dump" widget="ace" options="{'type': 'json'}" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Acción -->
    <record id="action_audit_log_delete" model="ir.actions.act_window">
        <field name="name">Registro de Eliminaciones</field>
        <field name="res_model">audit.log.delete</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Acción y Menú -->
    <menuitem
        id="audit_cros_menu"
        name="Auditoría"
        parent="base.menu_custom"
        sequence="10">

        <menuitem id="menu_audit_log_delete"
            name="Registro de Eliminaciones"
            action="action_audit_log_delete"
            sequence="1"
            groups="base.group_system"
        />

    </menuitem>

</odoo>
