<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="point_of_sale.PaymentScreenPaymentLines" t-inherit="point_of_sale.PaymentScreenPaymentLines" t-inherit-mode="extension">
        <xpath expr="//t[@t-if='line.isSelected()']//div[@class='payment-amount px-3']/t" position="replace">
            <t t-esc="line.get_converted_amount_display()" />
        </xpath>

        <xpath expr="//t[@t-else='']//div[@class='payment-amount px-3']/t" position="replace">
            <t t-esc="line.get_converted_amount_display()" />
        </xpath>
    </t>

</templates>
