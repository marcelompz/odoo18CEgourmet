<odoo>

    <record id="sale_order_inherit_form" model="ir.ui.view">
        <field name="name">sale.order.inherit.form</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale_margin.sale_margin_sale_order" />
        <field name="arch" type="xml">

            <xpath expr="//div[hasclass('float-end')]/label[@for='margin']/.." position="attributes">
                <attribute name="groups">sales_team.group_sale_manager</attribute>
            </xpath>
        
        </field>
    </record>

    <record id="sale_order_line_inherit" model="ir.ui.view">
        <field name="name">sale.order.line.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale_margin.sale_margin_sale_order_line_form"/>
        <field name="arch" type="xml">
            <!-- Modificamos el campo 'purchase_price' -->
            <xpath expr="//field[@name='order_line']/list//field[@name='purchase_price']" position="attributes">
                <attribute name="groups">sales_team.group_sale_manager</attribute>
            </xpath>
            
            <!-- Modificamos el campo 'margin' -->
            <xpath expr="//field[@name='order_line']/list//field[@name='margin']" position="attributes">
                <attribute name="groups">sales_team.group_sale_manager</attribute>
            </xpath>

            <!-- Modificamos el campo 'margin_percent' -->
            <xpath expr="//field[@name='order_line']/list//field[@name='margin_percent']" position="attributes">
                <attribute name="groups">sales_team.group_sale_manager</attribute>
            </xpath>
        </field>
    </record>

</odoo>
