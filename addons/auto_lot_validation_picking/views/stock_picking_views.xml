<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_picking_form_inherit_auto_lot" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit.auto.lot</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_auto_assign_lots_and_validate" 
                        string="Auto-Assign Lots &amp; Validate" 
                        type="object" 
                        class="oe_highlight" 
                        invisible="state != 'assigned' or picking_type_code != 'outgoing'"/>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_negative_records" type="object"
                        class="oe_stat_button" icon="fa-exclamation-triangle"
                        invisible="not has_negative_records">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Negative Stock</span>
                    </div>
                </button>
            </xpath>
            <xpath expr="//field[@name='origin']" position="after">
                <field name="lot_validation_state" widget="badge" 
                       decoration-warning="lot_validation_state == 'partial'"
                       decoration-danger="lot_validation_state == 'negative'"
                       decoration-success="lot_validation_state == 'done'"
                       invisible="picking_type_code != 'outgoing'"/>
                <field name="has_negative_records" invisible="1"/>
            </xpath>
        </field>
    </record>

    <record id="view_picking_tree_inherit_auto_lot" model="ir.ui.view">
        <field name="name">stock.picking.tree.inherit.auto.lot</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.vpicktree"/>
        <field name="arch" type="xml">
            <field name="state" position="after">
                <field name="lot_validation_state" widget="badge" 
                       decoration-warning="lot_validation_state == 'partial'"
                       decoration-danger="lot_validation_state == 'negative'"
                       decoration-success="lot_validation_state == 'done'"
                       optional="show"/>
            </field>
        </field>
    </record>

    <record id="action_pending_lot_validation" model="ir.actions.act_window">
        <field name="name">Pending Lot Validation</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '=', 'assigned'), ('picking_type_code', '=', 'outgoing')]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No deliveries pending lot allocation!
            </p>
        </field>
    </record>
    <record id="action_server_auto_assign_lots_validate" model="ir.actions.server">
        <field name="name">Auto-Assign Lots &amp; Validate</field>
        <field name="model_id" ref="stock.model_stock_picking"/>
        <field name="binding_model_id" ref="stock.model_stock_picking"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            if records:
                records.action_auto_assign_lots_and_validate()
        </field>
    </record>

</odoo>
