<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_stock_negative_record_tree" model="ir.ui.view">
        <field name="name">stock.negative.record.tree</field>
        <field name="model">stock.negative.record</field>
        <field name="arch" type="xml">
            <list string="Negative Inventory Records">
                <field name="name"/>
                <field name="date"/>
                <field name="product_id"/>
                <field name="picking_id"/>
                <field name="location_id"/>
                <field name="quantity"/>
                <field name="state" widget="badge" 
                       decoration-warning="state == 'pending'" 
                       decoration-success="state == 'reconciled'"/>
            </list>
        </field>
    </record>

    <record id="view_stock_negative_record_form" model="ir.ui.view">
        <field name="name">stock.negative.record.form</field>
        <field name="model">stock.negative.record</field>
        <field name="arch" type="xml">
            <form string="Negative Inventory Record">
                <header>
                    <button name="action_reconcile" string="Mark as Reconciled" type="object" class="oe_highlight" invisible="state == 'reconciled'"/>
                    <field name="state" widget="statusbar" statusbar_visible="pending,reconciled"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="product_id"/>
                            <field name="picking_id"/>
                            <field name="location_id"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="quantity"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_stock_negative_record_search" model="ir.ui.view">
        <field name="name">stock.negative.record.search</field>
        <field name="model">stock.negative.record</field>
        <field name="arch" type="xml">
            <search string="Search Negative Records">
                <field name="name"/>
                <field name="product_id"/>
                <field name="picking_id"/>
                <filter string="Pending" name="pending" domain="[('state', '=', 'pending')]"/>
                <filter string="Reconciled" name="reconciled" domain="[('state', '=', 'reconciled')]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_by_state" context="{'group_by': 'state'}"/>
                    <filter string="Product" name="group_by_product" context="{'group_by': 'product_id'}"/>
                    <filter string="Picking" name="group_by_picking" context="{'group_by': 'picking_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_stock_negative_record" model="ir.actions.act_window">
        <field name="name">Negative Inventory Adjustments</field>
        <field name="res_model">stock.negative.record</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_stock_negative_record_search"/>
        <field name="context">{'search_default_pending': 1}</field>
    </record>
</odoo>
