<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_lot_validation_log_tree" model="ir.ui.view">
        <field name="name">lot.validation.log.tree</field>
        <field name="model">lot.validation.log</field>
        <field name="arch" type="xml">
            <list string="Lot Validation Logs" create="0">
                <field name="date"/>
                <field name="picking_id"/>
                <field name="state" widget="badge" 
                       decoration-success="state == 'success'" 
                       decoration-warning="state == 'partial'" 
                       decoration-danger="state == 'failed'"/>
                <field name="notes" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_lot_validation_log_form" model="ir.ui.view">
        <field name="name">lot.validation.log.form</field>
        <field name="model">lot.validation.log</field>
        <field name="arch" type="xml">
            <form string="Lot Validation Log" create="0" edit="0">
                <sheet>
                    <group>
                        <group>
                            <field name="picking_id"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="state" widget="badge" 
                                   decoration-success="state == 'success'" 
                                   decoration-warning="state == 'partial'" 
                                   decoration-danger="state == 'failed'"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_lot_validation_log" model="ir.actions.act_window">
        <field name="name">Lot Validation Logs</field>
        <field name="res_model">lot.validation.log</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
