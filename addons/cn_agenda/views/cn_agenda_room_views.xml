<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- FORM VIEW -->
    <record id="view_cn_agenda_room_form" model="ir.ui.view">
        <field name="name">cn.agenda.room.form</field>
        <field name="model">cn.agenda.room</field>
        <field name="arch" type="xml">
            <form string="Room/Resource">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="capacity"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- TREE VIEW -->
    <record id="view_cn_agenda_room_tree" model="ir.ui.view">
        <field name="name">cn.agenda.room.tree</field>
        <field name="model">cn.agenda.room</field>
        <field name="arch" type="xml">
            <list string="Rooms/Resources">
                <field name="name"/>
                <field name="capacity"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_cn_agenda_room" model="ir.actions.act_window">
        <field name="name">Rooms &amp; Resources</field>
        <field name="res_model">cn.agenda.room</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
