<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_purchasing_planning_report_cross_tree" model="ir.ui.view">
        <field name="name">report.purchase.data.consolidated.list</field>
        <field name="model">report.purchase.data.consolidated</field>
        <field name="arch" type="xml">
            <list string="Planificación de Compras" create="0" edit="0" delete="0">
                <header>
                    <button name="%(purchasing_planning_report_cross.action_report_purchase_wizard)d" string="⚙ Actualizar Fechas" type="action" class="btn-primary"/>
                </header>
                <field name="id" string="ID" optional="hide"/>
                <field name="categ_id" string="Categoría" optional="show"/>
                <field name="default_code" string="Referencia" optional="show"/>
                <field name="product_id" string="Producto" optional="show"/>
                <field name="qty_purchased" string="Comprados" optional="show" sum="Total Comprados"/>
                <field name="amount_purchased" string="Valor compra" widget="monetary" options="{'currency_field': 'currency_id'}" optional="show" sum="Total Valor compra"/>
                <field name="qty_sold" string="Vendidos" optional="show" sum="Total Vendidos"/>
                <field name="amount_sold" string="Valor venta" widget="monetary" options="{'currency_field': 'currency_id'}" optional="show" sum="Total Valor venta"/>
                <field name="qty_available" string="Stock Actual" optional="show" sum="Total Stock"/>
                <field name="date_from" string="Desde" optional="show"/>
                <field name="date_to" string="Hasta" optional="show"/>
                <field name="last_vendor_id" string="Último Proveedor" optional="show"/>
                <field name="currency_id" column_invisible="True"/>
            </list>
        </field>
    </record>

    <record id="view_purchasing_planning_report_cross_form" model="ir.ui.view">
        <field name="name">report.purchase.data.consolidated.form</field>
        <field name="model">report.purchase.data.consolidated</field>
        <field name="arch" type="xml">
            <form string="Detalle de Planificación de Compras" create="0" edit="0" delete="0">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="product_id" readonly="1" options="{'no_open': True}"/>
                            <field name="qty_purchased" readonly="1"/>
                            <field name="amount_purchased" readonly="1"/>
                            <field name="qty_available" readonly="1"/>
                        </group>
                        <group>
                            <field name="default_code" readonly="1"/>
                            <field name="categ_id" readonly="1"/>
                            <field name="qty_sold" readonly="1"/>
                            <field name="amount_sold" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Productos comprados">
                            <field name="purchase_line_ids" readonly="1">
                                <list string="Productos Comprados" create="0" edit="0" delete="0">
                                    <button name="action_open_order" type="object" icon="fa-external-link" string="Ver Orden" title="Ver Orden"/>
                                    <field name="order_id" string="Referencia de la orden" widget="many2one" options="{'no_open': True}"/>
                                    <field name="product_id" string="Producto" widget="many2one" options="{'no_open': True}"/>
                                    <field name="date_approve" string="Fecha de confirmación"/>
                                    <field name="partner_id" string="Proveedor" widget="many2one" options="{'no_open': True}"/>
                                    <field name="currency_id" string="Moneda" widget="many2one" options="{'no_open': True}"/>
                                    <field name="product_qty" string="Cantidad" sum="Total Cantidad"/>
                                    <field name="price_unit" string="Precio unitario" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="price_subtotal" string="Total sin/iva" sum="Total sin/iva" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="price_total" string="Total c/iva" sum="Total c/iva" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                </list>
                            </field>
                        </page>
                        <page string="Productos Vendidos">
                            <field name="sale_line_ids" readonly="1">
                                <list string="Productos Vendidos" create="0" edit="0" delete="0">
                                    <button name="action_open_order" type="object" icon="fa-external-link" string="Ver Orden" title="Ver Orden"/>
                                    <field name="order_id" string="Referencia de la orden" widget="many2one" options="{'no_open': True}"/>
                                    <field name="product_id" string="Producto" widget="many2one" options="{'no_open': True}"/>
                                    <field name="create_date" string="Fecha de creación"/>
                                    <field name="order_partner_id" string="Cliente" widget="many2one" options="{'no_open': True}"/>
                                    <field name="currency_id" string="Moneda" widget="many2one" options="{'no_open': True}"/>
                                    <field name="product_uom_qty" string="Cantidad" sum="Total Cantidad"/>
                                    <field name="price_unit" string="Precio unitario" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="price_subtotal" string="Total sin/iva" sum="Total sin/iva" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="price_total" string="Total c/iva" sum="Total c/iva" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                </list>
                            </field>
                        </page>
                        <page string="Ventas PDV">
                            <field name="pos_line_ids" readonly="1">
                                <list string="Ventas PDV" create="0" edit="0" delete="0">
                                    <button name="action_open_order" type="object" icon="fa-external-link" string="Ver Orden" title="Ver Orden"/>
                                    <field name="order_id" string="Ref. de la orden" widget="many2one" options="{'no_open': True}"/>
                                    <field name="create_date" string="Creado el"/>
                                    <field name="product_id" string="Producto" widget="many2one" options="{'no_open': True}"/>
                                    <field name="report_partner_id" string="Cliente" widget="many2one" options="{'no_open': True}"/>
                                    <field name="currency_id" string="Moneda" widget="many2one" options="{'no_open': True}"/>
                                    <field name="qty" string="Cantidad" sum="Total Cantidad"/>
                                    <field name="price_unit" string="Precio unitario" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="price_subtotal" string="Total sin/iva" sum="Total sin/iva" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="price_subtotal_incl" string="Total c/IVA" sum="Total c/IVA" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_purchasing_planning_report_cross_search" model="ir.ui.view">
        <field name="name">report.purchase.data.consolidated.search</field>
        <field name="model">report.purchase.data.consolidated</field>
        <field name="arch" type="xml">
            <search string="Planeamiento Consolidado">
                <field name="name" string="Producto/Referencia" filter_domain="['|', ('name', 'ilike', self), ('default_code', 'ilike', self)]"/>
                <field name="default_code" string="Referencia"/>
            </search>
        </field>
    </record>

    <record id="action_purchasing_planning_report_cross" model="ir.actions.act_window">
        <field name="name">Planificación de Compras</field>
        <field name="res_model">report.purchase.data.consolidated</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_purchasing_planning_report_cross_tree"/>
        <field name="search_view_id" ref="view_purchasing_planning_report_cross_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Planificación de Compras
            </p>
        </field>
    </record>

    <menuitem id="menu_purchasing_planning_report_cross_root"
              name="Planificación de Compras"
              action="action_purchasing_planning_report_cross"
              parent="purchase.purchase_report_main"
              sequence="120"/>
</odoo>
