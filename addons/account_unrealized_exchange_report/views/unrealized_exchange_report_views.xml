<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_unrealized_exchange_report_line_tree" model="ir.ui.view">
        <field name="name">unrealized.exchange.report.line.list</field>
        <field name="model">unrealized.exchange.report.line</field>
        <field name="arch" type="xml">
            <list string="Detalle de Transacciones" create="0" edit="0" delete="0">
                <field name="date"/>
                <field name="move_line_id"/>
                <field name="transaction_type"/>
                <field name="currency_id"/>
                <field name="amount_currency" sum="Total Divisa"/>
                <field name="original_rate" digits="[12,6]"/>
                <field name="amount_company_original" sum="Total Original"/>
                <field name="current_rate" digits="[12,6]"/>
                <field name="amount_company_current" sum="Total Actualizado"/>
                <field name="unrealized_gain_loss" sum="Ganancia/Pérdida Total" widget="monetary" decoration-danger="unrealized_gain_loss &lt; 0" decoration-success="unrealized_gain_loss &gt; 0"/>
                <field name="company_currency_id" column_invisible="True"/>
            </list>
        </field>
    </record>

    <record id="view_unrealized_exchange_report_line_pivot" model="ir.ui.view">
        <field name="name">unrealized.exchange.report.line.pivot</field>
        <field name="model">unrealized.exchange.report.line</field>
        <field name="arch" type="xml">
            <pivot string="Análisis Pivot Ganancias/Pérdidas no Realizadas" disable_linking="True">
                <field name="currency_id" type="row"/>
                <field name="transaction_type" type="col"/>
                <field name="amount_currency" type="measure"/>
                <field name="amount_company_original" type="measure"/>
                <field name="amount_company_current" type="measure"/>
                <field name="unrealized_gain_loss" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_unrealized_exchange_report_line_graph" model="ir.ui.view">
        <field name="name">unrealized.exchange.report.line.graph</field>
        <field name="model">unrealized.exchange.report.line</field>
        <field name="arch" type="xml">
            <graph string="Gráfico Ganancias/Pérdidas no Realizadas" type="bar">
                <field name="currency_id"/>
                <field name="unrealized_gain_loss" type="measure"/>
            </graph>
        </field>
    </record>
</odoo>
