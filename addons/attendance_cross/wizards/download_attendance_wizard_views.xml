<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Wizard form for downloading attendance -->
        <record id="view_download_attendance_wizard_form" model="ir.ui.view">
            <field name="name">download.attendance.wizard.form</field>
            <field name="model">download.attendance.wizard</field>
            <field name="arch" type="xml">
                <form string="Download Attendance from Device">
                    <sheet>
                        <group>
                            <group>
                                <field name="device_id" required="1"/>
                                <field name="clear_existing"/>
                            </group>
                            <group>
                                <field name="start_date" required="1"/>
                                <field name="end_date" required="1"/>
                            </group>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_download" string="Download" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
        
        <!-- Action to open download wizard -->
        <record id="action_download_attendance_wizard" model="ir.actions.act_window">
            <field name="name">Download Attendance</field>
            <field name="res_model">download.attendance.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="binding_model_id" ref="model_biometric_device"/>
            <field name="binding_view_types">form</field>
        </record>
    </data>
</odoo>