<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Demo data for testing -->
        <record id="demo_biometric_device_1" model="biometric.device">
            <field name="name">Main Entrance Device</field>
            <field name="ip_address">192.168.1.100</field>
            <field name="port">80</field>
            <field name="username">admin</field>
            <field name="password">biometric123</field>
            <field name="active">True</field>
        </record>
        
        <record id="demo_biometric_device_2" model="biometric.device">
            <field name="name">Back Office Device</field>
            <field name="ip_address">192.168.1.101</field>
            <field name="port">80</field>
            <field name="username">admin</field>
            <field name="password">biometric123</field>
            <field name="active">True</field>
        </record>
        
        <!-- Demo attendance logs -->
        <record id="demo_attendance_log_1" model="attendance.log">
            <field name="employee_id" ref="hr.employee_admin"/>
            <field name="device_id" ref="demo_biometric_device_1"/>
            <field name="check_time" eval="(datetime.now() - timedelta(days=1, hours=9)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="check_type">check_in</field>
            <field name="processed">False</field>
        </record>
        
        <record id="demo_attendance_log_2" model="attendance.log">
            <field name="employee_id" ref="hr.employee_admin"/>
            <field name="device_id" ref="demo_biometric_device_1"/>
            <field name="check_time" eval="(datetime.now() - timedelta(days=1, hours=17)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="check_type">check_out</field>
            <field name="processed">False</field>
        </record>
    </data>
</odoo>